# keystore.properties — NEVER commit the real version of this file.
# Copy this to keystore.properties and fill in your actual values.
#
# Generate a release keystore:
#   keytool -genkey -v -keystore chatly-release.jks -alias chatly \
#           -keyalg RSA -keysize 2048 -validity 10000

storeFile=../chatly-release.jks
storePassword=YOUR_STRONG_STORE_PASSWORD
keyAlias=chatly
keyPassword=YOUR_STRONG_KEY_PASSWORD
