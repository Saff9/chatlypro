# Node environment
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database configurations
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatly
# CA certificate for production database SSL verification
DATABASE_CA_CERT=

# Redis configurations
REDIS_URL=redis://localhost:6379

# JWT secret key for token sign/verify (at least 32 characters)
JWT_SECRET=replace-with-a-strong-random-key-in-prod-at-least-32-chars

# Encryption keys and pepper secrets
EMAIL_ENCRYPTION_KEY=replace-with-32-plus-byte-random-secret
EMAIL_HASH_SALT=replace-with-32-plus-byte-random-secret

# CORS Allowed Origins (comma-separated list, required in production)
ALLOWED_ORIGINS=http://localhost:3000

# OTP and Verification Bypass (development only, set false in prod)
CHATLY_DEV_OTP_BYPASS=false
